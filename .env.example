# 服务器配置
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# 日志级别 (debug, info, warn, error)
RUST_LOG=info

# PostgreSQL 数据库连接
DATABASE_URL=postgresql://user:password@ip:port/dbname
# 通义千问 API 密钥
# 请访问 https://bailian.console.aliyun.com/ 获取你的 API Key
# 然后将下面的 your_dashscope_api_key_here 替换为你的真实 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# OpenAI API 密钥（可选，如果使用 OpenAI 模型）
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API 密钥（可选，如果使用 Claude 模型）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cohere API 密钥（可选，如果使用 Cohere 模型）
COHERE_API_KEY=your_cohere_api_key_here

# MCP 服务器配置（可选）
# MCP服务器URL，用于工具调用功能
MCP_SERVER_URL=http://127.0.0.1:10001/mcp

# MCP API密钥（如果MCP服务器需要认证）
MCP_API_KEY=key